# .skills-manager secrets
# Copy this to .env and fill in your actual values.
# .env is gitignored — never commit it.

# GitHub personal access token (for marketplace operations)
SKILLS_MANAGER_GITHUB_TOKEN=ghp_your_token_here

# LLM provider API key (e.g. Google AI / Gemini)
SKILLS_MANAGER_API_KEY=your_api_key_here

# OAuth session tokens (populated during auth flow)
SKILLS_MANAGER_AUTH_ACCESS_TOKEN=
SKILLS_MANAGER_AUTH_REFRESH_TOKEN=
